# tushare Pro token (2000+ points recommended)
TUSHARE_TOKEN=your_tushare_token_here

# akshare optional proxy
AKSHARE_PROXY=

# Data root. Leave UNSET to use the project-local default
# (~/.code/quant-meta-team/quant_data/data) — see docs/data-localization.md v0.4 §6.5.
# Set to /Volumes/RSS_DATA/quant_data once the external drive is mounted.
# DATA_DIR=/Volumes/RSS_DATA/quant_data

# Logs
LOG_DIR=~/Code/quant-meta-team/logs
