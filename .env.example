# tushare Pro token (2000+ points recommended)
TUSHARE_TOKEN=your_tushare_token_here

# akshare optional proxy
AKSHARE_PROXY=

# Data root — RSS_DATA external drive (active since 2026-06-11).
# See docs/data-localization.md v0.4 §6.5 + §6.6 for migration SOP.
# Leave UNSET to fall back to project-local default
# (~/.code/quant-meta-team/quant_data/data).
DATA_DIR=/Volumes/RSS_DATA/quant_data

# Logs
LOG_DIR=~/Code/quant-meta-team/logs
